# ---- AMPLIFY runtime configuration ----
AMPLIFY_BACKEND=hf                # hf | lmstudio | termux
AMPLIFY_HOST=0.0.0.0
AMPLIFY_PORT=5000
AMPLIFY_DEBUG=false

# Model
AMPLIFY_MODEL_ID=Rta-AILabs/Nandi-Mini-150M-Instruct
AMPLIFY_MAX_NEW_TOKENS=256
AMPLIFY_TEMPERATURE=0.7

# External backends
AMPLIFY_LM_STUDIO_URL=http://host.docker.internal:1234/v1/chat/completions
AMPLIFY_TERMUX_URL=http://127.0.0.1:8080/v1/chat/completions

# Telemetry
AMPLIFY_LOG_PATH=data/amplify_chat_history.csv

# Dashboard
AMPLIFY_DASHBOARD_PASSWORD=changeme
